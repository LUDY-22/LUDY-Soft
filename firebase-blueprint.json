{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "displayName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "manager", "cashier"] },
        "storeId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "storeId"]
    },
    "Store": {
      "title": "Store",
      "description": "Store information",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "address": { "type": "string" },
        "phone": { "type": "string" },
        "receiptHeader": { "type": "string" },
        "receiptFooter": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name"]
    },
    "Product": {
      "title": "Product",
      "description": "Product in inventory",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "name": { "type": "string" },
        "category": { "type": "string" },
        "buyPrice": { "type": "number" },
        "sellPrice": { "type": "number" },
        "stock": { "type": "number" },
        "minStock": { "type": "number" },
        "barcode": { "type": "string" },
        "imageUrl": { "type": "string" },
        "storeId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "name", "buyPrice", "sellPrice", "storeId"]
    },
    "Sale": {
      "title": "Sale",
      "description": "Sale transaction record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "items": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "productId": { "type": "string" },
              "name": { "type": "string" },
              "quantity": { "type": "number" },
              "price": { "type": "number" },
              "total": { "type": "number" },
              "profit": { "type": "number" }
            }
          }
        },
        "total": { "type": "number" },
        "paymentMethod": { "type": "string", "enum": ["cash", "card", "transfer"] },
        "cashierId": { "type": "string" },
        "storeId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "items", "total", "paymentMethod", "cashierId", "storeId", "timestamp"]
    },
    "Movement": {
      "title": "Movement",
      "description": "Stock movement record",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "productId": { "type": "string" },
        "productName": { "type": "string" },
        "type": { "type": "string", "enum": ["in", "out"] },
        "quantity": { "type": "number" },
        "reason": { "type": "string" },
        "userId": { "type": "string" },
        "storeId": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "productId", "type", "quantity", "storeId", "timestamp"]
    },
    "Log": {
      "title": "Log",
      "description": "Audit log entry",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "action": { "type": "string" },
        "description": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" },
        "storeId": { "type": "string" }
      },
      "required": ["id", "userId", "action", "storeId", "timestamp"]
    }
  },
  "firestore": {
    "/users/{uid}": {
      "schema": "UserProfile",
      "description": "User profiles"
    },
    "/stores/{storeId}": {
      "schema": "Store",
      "description": "Store details"
    },
    "/products/{productId}": {
      "schema": "Product",
      "description": "Inventory products"
    },
    "/sales/{saleId}": {
      "schema": "Sale",
      "description": "Sales records"
    },
    "/movements/{movementId}": {
      "schema": "Movement",
      "description": "Stock movements"
    },
    "/logs/{logId}": {
      "schema": "Log",
      "description": "Audit logs"
    }
  }
}
